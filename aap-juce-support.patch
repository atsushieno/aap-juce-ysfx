+
+        m_androidLoadFiles.clear();
+        m_androidLoadPopup.reset(new juce::PopupMenu);
+
+        std::function<void(juce::PopupMenu&, const juce::File&)> populate =
+            [&](juce::PopupMenu& menu, const juce::File& dir) {
+                juce::Array<juce::File> children;
+                dir.findChildFiles(children, juce::File::findFilesAndDirectories, false);
+                children.sort();
+                for (const auto& child : children) {
+                    if (child.isDirectory()) {
+                        juce::PopupMenu sub;
+                        populate(sub, child);
+                        if (sub.getNumItems() > 0)
+                            menu.addSubMenu(child.getFileName(), sub);
