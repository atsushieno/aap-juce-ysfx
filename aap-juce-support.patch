+        // Derive <applicationId> at runtime rather than hardcoding it, so the
+        // same code works for every app that bundles ysfx (e.g. ysfx-s-fx and
+        // ysfx-s-instrument, whose applicationIds differ). JUCE's
+        // userApplicationDataDirectory is /data/user/0/<applicationId>, so its
+        // file name is the applicationId.
+        const juce::String applicationId =
+            juce::File::getSpecialLocation(juce::File::userApplicationDataDirectory).getFileName();
